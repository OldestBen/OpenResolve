# OpenResolve — environment configuration
# ─────────────────────────────────────────
# The easiest way to set this up is: ./setup.sh
# It generates this file for you with a secure JWT secret.
#
# To configure manually: copy this file to .env and fill in the values.
#   cp .env.example .env

# Port to expose on your host machine
HOST_PORT=3000

# JWT secret — CHANGE THIS. Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string

# Admin account (used on first startup only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=openresolve

# ── Optional: Email alias ingestion ──────────────────────────────────
# Uncomment and use docker-compose.email.yml to enable per-case email aliases.
# See README.md for Cloudflare Email Routing setup instructions.
#
# EMAIL_INGESTION_ENABLED=true
# EMAIL_DOMAIN=cases.yourdomain.com
# WEBHOOK_SECRET=another_long_random_string
