# OpenResolve configuration
# Copy to .env and fill in values

# The port to expose the app on your host machine
HOST_PORT=3000

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string

# Initial admin credentials (used on first run to create the admin user)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# ── Optional: Email ingestion ────────────────────────────────────────────────
# Only needed when using docker-compose.email.yml
# EMAIL_DOMAIN=cases.yourdomain.com
# WEBHOOK_SECRET=another_long_random_string
